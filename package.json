{
  "name": "z-code",
  "version": "0.1.0",
  "description": "AI Coding agent CLI tool",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "scripts",
    "prompts"
  ],
  "bin": {
    "z-code": "dist/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "rm -rf dist && tsc && cp ./src/tools/*.txt dist/tools/ && cp ./prompts dist/agent -rf && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.66",
    "@ai-sdk/openai": "latest",
    "@ai-sdk/openai-compatible": "^2.0.46",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.175",
    "chalk": "latest",
    "cheerio": "^1.2.0",
    "commander": "latest",
    "diff": "^9.0.0",
    "fs-extra": "latest",
    "glob": "^13.0.6",
    "node-fetch": "^3.3.2",
    "ollama-ai-provider-v2": "^3.5.0",
    "ora": "^9.4.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/diff": "^7.0.2",
    "@types/fs-extra": "latest",
    "@types/glob": "^8.1.0",
    "@types/node": "latest",
    "@types/node-fetch": "^2.6.13",
    "tsx": "^4.21.0",
    "typescript": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com-zzlee:zzlee/z-code.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
